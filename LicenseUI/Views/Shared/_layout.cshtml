<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            font-family: Arial;
            margin: 20px;
        }

        input {
            padding: 6px;
            margin-right: 10px;
        }

        button {
            padding: 6px 12px;
            background: #007bff;
            color: white;
            border: none;
            cursor: pointer;
        }

            button:hover {
                background: #0056b3;
            }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #f5f5f5;
            padding: 10px;
        }
    </style>

    <title>License Management System</title>
</head>
<body>

    <div class="header">
        <h2>License Management System</h2>

        @{
            var role = Context.Session.GetString("role");
        }

        @if (!string.IsNullOrEmpty(role))
        {
            <form method="post" action="/Auth/Logout">
                @Html.AntiForgeryToken()
                <button type="submit">Logout</button>
            </form>
        }
    </div>

    <hr />

    @RenderBody()

</body>
</html>